# 42soccer environment variables — copy to .env.local and fill in.
# .env.local is gitignored. The key is read server-side only (process.env),
# never exposed to the browser, never committed.

# API-Football (https://www.api-football.com) — REST key, header x-apisports-key.
FOOTBALL_API_KEY=

# Provider selector. "apiFootball" (default) or "footballDataOrg" (PL-only fallback stub).
PROVIDER=apiFootball
